    <title>Lịch sử Internet</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, Helvetica, sans-serif;
            background: #f4f6f9;
            color: #333;
            line-height: 1.7;
        }

        /* NAVBAR */
        nav {
            background: #0d6efd;
            padding: 15px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        nav ul {
            list-style: none;
            display: flex;
            justify-content: center;
        }

        nav ul li {
            margin: 0 25px;
        }

        nav ul li a {
            color: white;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

        nav ul li a:hover {
            color: yellow;
        }

        /* CONTAINER */
        .container {
            width: 85%;
            max-width: 1100px;
            margin: 40px auto;
            background: white;
            padding: 35px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        h1 {
            text-align: center;
            color: #0d6efd;
            margin-bottom: 25px;
            padding-bottom: 10px;
            border-bottom: 3px solid #0d6efd;
        }

        h2 {
            color: #0d6efd;
            margin-top: 40px;
            margin-bottom: 15px;
            border-left: 5px solid #0d6efd;
            padding-left: 10px;
        }

        p {
            margin-bottom: 20px;
            text-align: justify;
        }

        .image-box {
            text-align: center;
            margin: 30px 0;
        }

        .image-box img {
            width: 100%;
            max-width: 650px;
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

        .image-box i {
            display: block;
            margin-top: 10px;
            color: gray;
        }

        footer {
            text-align: center;
            padding: 20px;
            background: #0d6efd;
            color: white;
            margin-top: 40px;
        }

        html {
            scroll-behavior: smooth;
        }

        @media (max-width: 768px) {
            .container {
                width: 95%;
                padding: 20px;
            }

            nav ul {
                flex-direction: column;
                align-items: center;
            }

            nav ul li {
                margin: 10px 0;
            }
        }
    </style>
</head>

